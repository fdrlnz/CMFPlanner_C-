<UserControl x:Class="CMFPlanner.UI.TriplanarViewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helix="http://helix-toolkit.org/wpf"
             Background="#0D0D0D">

    <UserControl.Resources>
        <Style x:Key="PresetBtn" TargetType="Button">
            <Setter Property="Background"      Value="#2D2D2D"/>
            <Setter Property="Foreground"      Value="#AAAAAA"/>
            <Setter Property="BorderBrush"     Value="#3E3E42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="6,3"/>
            <Setter Property="Margin"          Value="2,0"/>
            <Setter Property="FontSize"        Value="10"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3E3E42"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0078D4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!-- 3-row × 3-col grid: content / 2px separator / content -->
    <Grid x:Name="ViewportGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="2"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="2"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Separators -->
        <Rectangle x:Name="HSeparator"
                   Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                   Fill="#3E3E42"/>
        <Rectangle x:Name="VSeparator"
                   Grid.Row="0" Grid.Column="1" Grid.RowSpan="3"
                   Fill="#3E3E42"/>

        <!-- ══ AXIAL  (top-left) ══════════════════════════════════════ -->
        <Border x:Name="AxialBorder" Grid.Row="0" Grid.Column="0" ClipToBounds="True">
            <Grid>
                <Grid x:Name="AxialGrid" Width="1" Height="1" Background="Black"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      Cursor="Cross"
                      MouseLeftButtonDown="AnyGrid_MouseLeftButtonDown"
                      MouseRightButtonDown="AnyGrid_MouseRightButtonDown"
                      MouseDown="AnyGrid_MouseDown"
                      MouseLeftButtonUp="AnyGrid_MouseUp"
                      MouseRightButtonUp="AnyGrid_MouseUp"
                      MouseUp="AnyGrid_MouseUp"
                      MouseMove="AnyGrid_MouseMove"
                      MouseWheel="AnyGrid_MouseWheel">
                    <Grid.ContextMenu><x:Null/></Grid.ContextMenu>
                    <Image x:Name="AxialImage" Stretch="Fill"
                           RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                    <Canvas x:Name="AxialGridCanvas" Width="1" Height="1" IsHitTestVisible="False"/>
                    <Canvas x:Name="AxialCanvas" Width="1" Height="1" IsHitTestVisible="False">
                        <Line x:Name="AxialHLine" Stroke="#44BB44" StrokeThickness="0.8"/>
                        <Line x:Name="AxialVLine" Stroke="#FF8800" StrokeThickness="0.8"/>
                    </Canvas>
                </Grid>
                <Border Background="#55000000" HorizontalAlignment="Left" VerticalAlignment="Top"
                        Padding="5,2" Margin="4" IsHitTestVisible="False">
                    <TextBlock Text="AXIAL" Foreground="#44BB44" FontSize="10" FontWeight="SemiBold"/>
                </Border>
            </Grid>
        </Border>

        <!-- ══ CORONAL  (top-right) ══════════════════════════════════ -->
        <Border x:Name="CoronalBorder" Grid.Row="0" Grid.Column="2" ClipToBounds="True">
            <Grid>
                <Grid x:Name="CoronalGrid" Width="1" Height="1" Background="Black"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      Cursor="Cross"
                      MouseLeftButtonDown="AnyGrid_MouseLeftButtonDown"
                      MouseRightButtonDown="AnyGrid_MouseRightButtonDown"
                      MouseDown="AnyGrid_MouseDown"
                      MouseLeftButtonUp="AnyGrid_MouseUp"
                      MouseRightButtonUp="AnyGrid_MouseUp"
                      MouseUp="AnyGrid_MouseUp"
                      MouseMove="AnyGrid_MouseMove"
                      MouseWheel="AnyGrid_MouseWheel">
                    <Grid.ContextMenu><x:Null/></Grid.ContextMenu>
                    <Image x:Name="CoronalImage" Stretch="Fill"
                           RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                    <Canvas x:Name="CoronalGridCanvas" Width="1" Height="1" IsHitTestVisible="False"/>
                    <Canvas x:Name="CoronalCanvas" Width="1" Height="1" IsHitTestVisible="False">
                        <Line x:Name="CoronalHLine" Stroke="#4488FF" StrokeThickness="0.8"/>
                        <Line x:Name="CoronalVLine" Stroke="#FF8800" StrokeThickness="0.8"/>
                    </Canvas>
                </Grid>
                <Border Background="#55000000" HorizontalAlignment="Left" VerticalAlignment="Top"
                        Padding="5,2" Margin="4" IsHitTestVisible="False">
                    <TextBlock Text="CORONAL" Foreground="#4488FF" FontSize="10" FontWeight="SemiBold"/>
                </Border>
            </Grid>
        </Border>

        <!-- ══ SAGITTAL  (bottom-left) ══════════════════════════════ -->
        <Border x:Name="SagittalBorder" Grid.Row="2" Grid.Column="0" ClipToBounds="True">
            <Grid>
                <Grid x:Name="SagittalGrid" Width="1" Height="1" Background="Black"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      Cursor="Cross"
                      MouseLeftButtonDown="AnyGrid_MouseLeftButtonDown"
                      MouseRightButtonDown="AnyGrid_MouseRightButtonDown"
                      MouseDown="AnyGrid_MouseDown"
                      MouseLeftButtonUp="AnyGrid_MouseUp"
                      MouseRightButtonUp="AnyGrid_MouseUp"
                      MouseUp="AnyGrid_MouseUp"
                      MouseMove="AnyGrid_MouseMove"
                      MouseWheel="AnyGrid_MouseWheel">
                    <Grid.ContextMenu><x:Null/></Grid.ContextMenu>
                    <Image x:Name="SagittalImage" Stretch="Fill"
                           RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                    <Canvas x:Name="SagittalGridCanvas" Width="1" Height="1" IsHitTestVisible="False"/>
                    <Canvas x:Name="SagittalCanvas" Width="1" Height="1" IsHitTestVisible="False">
                        <Line x:Name="SagittalHLine" Stroke="#4488FF" StrokeThickness="0.8"/>
                        <Line x:Name="SagittalVLine" Stroke="#44BB44" StrokeThickness="0.8"/>
                    </Canvas>
                </Grid>
                <Border Background="#55000000" HorizontalAlignment="Left" VerticalAlignment="Top"
                        Padding="5,2" Margin="4" IsHitTestVisible="False">
                    <TextBlock Text="SAGITTAL" Foreground="#FF8800" FontSize="10" FontWeight="SemiBold"/>
                </Border>
            </Grid>
        </Border>

        <!-- ══ 3D BONE PREVIEW  (bottom-right) ═══════════════════════════ -->
        <Border x:Name="InfoBorder" Grid.Row="2" Grid.Column="2" ClipToBounds="True"
                Background="#111111">
            <Grid x:Name="Preview3DContainer"
                  Background="Transparent"
                  IsManipulationEnabled="True"
                  ManipulationStarting="Preview3DContainer_ManipulationStarting"
                  ManipulationStarted="Preview3DContainer_ManipulationStarted"
                  ManipulationDelta="Preview3DContainer_ManipulationDelta"
                  ManipulationInertiaStarting="Preview3DContainer_ManipulationInertiaStarting"
                  MouseLeftButtonDown="Preview3DContainer_MouseLeftButtonDown"
                  MouseLeftButtonUp="Preview3DContainer_MouseLeftButtonUp"
                  MouseMove="Preview3DContainer_MouseMove"
                  MouseLeave="Preview3DContainer_MouseLeave"
                  MouseWheel="Preview3DContainer_MouseWheel">

                <!-- HelixViewport3D: camera controlled by our own mouse handlers -->
                <helix:HelixViewport3D x:Name="Preview3D"
                                       Background="#111111"
                                       ShowCoordinateSystem="False"
                                       ShowFrameRate="False"
                                       IsRotationEnabled="False"
                                       IsMoveEnabled="False"
                                       IsPanEnabled="False"
                                       IsZoomEnabled="False"
                                       IsHitTestVisible="False">
                    <helix:HelixViewport3D.ContextMenu>
                        <x:Null/>
                    </helix:HelixViewport3D.ContextMenu>
                </helix:HelixViewport3D>

                <!-- 2D metric grid overlay (drawn in code-behind, like CT slices) -->
                <Canvas x:Name="Preview3DGridCanvas" IsHitTestVisible="False"/>

                <!-- No-mesh placeholder -->
                <TextBlock x:Name="NoMeshText"
                           Text="Load DICOM to see 3D preview"
                           Foreground="#444444" FontSize="11"
                           TextAlignment="Center" LineHeight="20"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False"/>

                <!-- Panel label -->
                <Border Background="#55000000" HorizontalAlignment="Left" VerticalAlignment="Top"
                        Padding="5,2" Margin="4" IsHitTestVisible="False">
                    <TextBlock Text="3D PREVIEW" Foreground="#FF8800" FontSize="10" FontWeight="SemiBold"/>
                </Border>

                <!-- Live bone threshold slider overlay -->
                <Border x:Name="ThresholdOverlay"
                        HorizontalAlignment="Stretch" VerticalAlignment="Bottom"
                        Background="#CC1A1A1A" Padding="10,8"
                        Visibility="Collapsed"
                        IsHitTestVisible="True">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Bone HU " Foreground="#AAAAAA"
                                   FontSize="10" VerticalAlignment="Center"/>
                        <Slider x:Name="LiveBoneSlider"
                                Grid.Column="1"
                                Minimum="200" Maximum="1200" Value="490"
                                VerticalAlignment="Center"
                                IsSnapToTickEnabled="False"
                                ValueChanged="LiveBoneSlider_ValueChanged"
                                ToolTip="Drag to adjust bone threshold (Mimics default: 490)"/>
                        <TextBlock x:Name="LiveBoneLabel"
                                   Grid.Column="2"
                                   Text="490 HU"
                                   Foreground="#CCCCCC" FontSize="10"
                                   VerticalAlignment="Center" Margin="8,0,0,0" Width="55"/>
                    </Grid>
                </Border>

                <!-- ── Zone-control hint overlay ────────────────────────────────
                     Shown once on first hover in the top-50 %, fades after 3 s.
                     Click anywhere to permanently dismiss.                    -->
                <Grid x:Name="ZoneHintOverlay" Visibility="Collapsed" IsHitTestVisible="True">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>   <!-- top    25 % of viewport = YAW / ROLL row   -->
                        <RowDefinition Height="*"/>   <!-- middle 25 % of viewport = PITCH corners     -->
                        <RowDefinition Height="2*"/>  <!-- bottom 50 % of viewport = free rotate       -->
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>  <!-- left   37.5 % (YAW/PITCH-L, +50 %) -->
                        <ColumnDefinition Width="3*"/>  <!-- center 37.5 %                       -->
                        <ColumnDefinition Width="2*"/>  <!-- right  25   % (ROLL/PITCH-R)        -->
                    </Grid.ColumnDefinitions>

                    <!-- YAW — top-left -->
                    <Border Grid.Row="0" Grid.Column="0" Background="#550088FF" BorderBrush="#990088FF" BorderThickness="1">
                        <TextBlock Text="↺ YAW" Foreground="#AADDFF" FontSize="10" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <!-- CENTER FREE — rows 0-1, center column -->
                    <Border Grid.Row="0" Grid.Column="1" Grid.RowSpan="2" Background="#22FFFFFF">
                        <TextBlock Text="FREE ROTATE" Foreground="#55FFFFFF" FontSize="10" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <!-- ROLL — top-right -->
                    <Border Grid.Row="0" Grid.Column="2" Background="#55FF8800" BorderBrush="#99FF8800" BorderThickness="1">
                        <TextBlock Text="↻ ROLL" Foreground="#FFDDAA" FontSize="10" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <!-- PITCH — mid-left -->
                    <Border Grid.Row="1" Grid.Column="0" Background="#5500DD88" BorderBrush="#9900DD88" BorderThickness="1">
                        <TextBlock Text="↕ PITCH" Foreground="#AAFFCC" FontSize="10" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <!-- PITCH — mid-right -->
                    <Border Grid.Row="1" Grid.Column="2" Background="#5500DD88" BorderBrush="#9900DD88" BorderThickness="1">
                        <TextBlock Text="↕ PITCH" Foreground="#AAFFCC" FontSize="10" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <!-- FREE bottom half -->
                    <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Background="#18FFFFFF">
                        <TextBlock Text="FREE ROTATE" Foreground="#33FFFFFF" FontSize="10" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>

                <!-- Animated directional arrows — shown on zone hover -->
                <Canvas x:Name="ZoneArrowCanvas" IsHitTestVisible="False"/>

                <!-- Floating zone label — follows cursor, shown only inside named zones -->
                <Canvas x:Name="ZoneLabelCanvas" IsHitTestVisible="False">
                    <Border x:Name="ZoneLabelBorder"
                            Background="#CC1A1A2E" CornerRadius="4" Padding="7,3"
                            Visibility="Collapsed">
                        <TextBlock x:Name="ZoneLabelText"
                                   Foreground="#FFEEAA" FontSize="11" FontWeight="Bold"/>
                    </Border>
                </Canvas>

            </Grid>
        </Border>

    </Grid>
</UserControl>
